# Hindsight server LLM config (consumed by the Hindsight Docker container).
# Hindsight is OpenAI-API-compatible, so any OAI-shaped endpoint works.
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://api.fireworks.ai/inference/v1
HINDSIGHT_API_LLM_MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
HINDSIGHT_API_LLM_API_KEY=fw_replace_me

# Bridge config (consumed by hindsight-bridge.py and test-local.sh).
HINDSIGHT_BASE_URL=http://localhost:8888
HINDSIGHT_BANK_ID=review-with-memory
